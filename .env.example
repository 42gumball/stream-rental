# Copy this file to .env and fill in the values.

# --- Database ---
# Dev: SQLite. Production: a hosted Postgres URL (Neon/Supabase/Railway).
DATABASE_URL="file:./dev.db"

# --- Auth (owner login) ---
APP_PASSWORD="set-a-strong-password"
SESSION_SECRET="a-long-random-string"

# --- Cron protection ---
CRON_SECRET="a-long-random-string"

# --- Reminders behaviour ---
REMINDER_LEAD_DAYS="5"
OWNER_NAME="Your business name"
OWNER_EMAIL="you@example.com"
OWNER_PHONE="+2449XXXXXXXX"

# --- SMS via Twilio ---
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM="+1XXXXXXXXXX"

# --- Email via Resend ---
RESEND_API_KEY=""
RESEND_FROM="reminders@yourdomain.com"
