# Copy this file to .env and fill in the values.

# --- Database ---
# Dev: SQLite. Production: a hosted Postgres URL (Neon/Supabase/Railway).
DATABASE_URL="file:./dev.db"

# --- Auth (owner login) ---
APP_PASSWORD="set-a-strong-password"
SESSION_SECRET="a-long-random-string"

# --- Cron protection ---
CRON_SECRET="a-long-random-string"

# --- Reminders behaviour ---
REMINDER_LEAD_DAYS="5"
OWNER_NAME="Your business name"
OWNER_EMAIL="you@example.com"
OWNER_PHONE="+2449XXXXXXXX"

# --- SMS via TelcoSMS (https://telcosms.co.ao) ---
TELCOSMS_API_URL="https://api.telcosms.co.ao/..."   # your account's send endpoint
TELCOSMS_API_TOKEN=""                                # your API token/key
TELCOSMS_SENDER="StreamRent"                          # sender name shown to customers

# --- Email via Resend ---
RESEND_API_KEY=""
RESEND_FROM="reminders@yourdomain.com"
